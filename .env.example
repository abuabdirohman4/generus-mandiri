# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Self-hosted data plane (optional). When set, all .from()/.rpc() queries go
# to this PostgREST instead of Supabase Cloud (auth stays on Supabase).
# Unset = legacy behavior (everything on Supabase Cloud). See selfhost/README.md
NEXT_PUBLIC_DATA_POSTGREST_URL=

# Dummy Data Control
NEXT_PUBLIC_USE_DUMMY_DATA=false

# Umami Analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=