# Test Environment Variables
# Copy this file to .env.test and fill with your test credentials
# NEVER commit .env.test to git!

# Base URL for testing
TEST_BASE_URL=http://localhost:3000

# ==============================================
# Test User Credentials (by Role)
# ==============================================
# ⚠️ IMPORTANT: Replace these placeholder values with your actual test credentials!
# These are just examples - DO NOT use in production!

# Superadmin (Full access to everything)
TEST_SUPERADMIN_USERNAME=your_test_superadmin_username
TEST_SUPERADMIN_PASSWORD=your_test_superadmin_password

# Admin Daerah (Regional admin - access to all kelompok in daerah)
TEST_ADMIN_DAERAH_USERNAME=your_test_admin_daerah_username
TEST_ADMIN_DAERAH_PASSWORD=your_test_admin_daerah_password

# Admin Desa (Village admin - access to all kelompok in desa)
TEST_ADMIN_DESA_USERNAME=your_test_admin_desa_username
TEST_ADMIN_DESA_PASSWORD=your_test_admin_desa_password

# Admin Kelompok (Group admin - access to one kelompok only)
TEST_ADMIN_KELOMPOK_USERNAME=your_test_admin_kelompok_username
TEST_ADMIN_KELOMPOK_PASSWORD=your_test_admin_kelompok_password

# Guru Daerah (Regional teacher - access to all classes in daerah)
TEST_GURU_DAERAH_USERNAME=your_test_guru_daerah_username
TEST_GURU_DAERAH_PASSWORD=your_test_guru_daerah_password

# Guru Desa (Village teacher - access to classes in desa)
TEST_GURU_DESA_USERNAME=your_test_guru_desa_username
TEST_GURU_DESA_PASSWORD=your_test_guru_desa_password

# Guru Kelompok (Group teacher - access to assigned classes only)
TEST_GURU_KELOMPOK_USERNAME=your_test_guru_kelompok_username
TEST_GURU_KELOMPOK_PASSWORD=your_test_guru_kelompok_password

# Optional: Student (for future student portal)
# TEST_STUDENT_USERNAME=your_test_student_username
# TEST_STUDENT_PASSWORD=your_test_student_password

# ==============================================
# Setup Instructions:
# ==============================================
# 1. Copy this file: cp .env.test.example .env.test
# 2. Replace all "your_test_*" placeholders with actual test credentials
# 3. Create corresponding test users in your test database
# 4. NEVER commit .env.test to Git (already in .gitignore)
#
# Security Notes:
# - Use DIFFERENT credentials than production
# - Use dedicated test accounts only
# - Test against localhost or test database ONLY
# - Never test against production database!
