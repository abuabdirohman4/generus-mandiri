# Copy to selfhost/.env.selfhost (gitignored) and fill in.

# Supabase dashboard -> Connect -> Session pooler (IPv4-safe) connection string.
# Format: postgresql://postgres.eahntxowlefjaizjoqys:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# Supabase dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret (legacy).
SUPABASE_JWT_SECRET=

# Supabase GoTrue menambahkan header `kid` pada access token user. PostgREST 14
# hanya cocokkan key by kid kalau kid ada -> secret polos gagal ("No suitable key").
# Isi dengan kid dari header token user mana pun (decode di jwt.io -> header.kid).
# run-postgrest.sh membungkus JWT secret jadi JWK Set: entri tanpa-kid (anon/service_role
# legacy) + entri ber-kid (token user). Tanpa ini, request user (RLS) 401.
SUPABASE_JWT_KID=

# Optional overrides
# LOCAL_DB=generus_local
# POSTGREST_PORT=3001
